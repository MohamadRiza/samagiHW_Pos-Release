{
  "name": "samagi-pos",
  "version": "1.0.7",
  "description": "Samagi Hardware POS System",
  "main": "electron/main.js",
  "author": "Nexasoft Solutions",
  "license": "Proprietary", 
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run backend:dev\" \"npm run frontend:dev\" \"wait-on http://localhost:3003 && electron .\"",
    "electron:publish": "npm run build && electron-builder --win --publish always",
    "backend:dev": "cd backend && npm run dev",
    "frontend:dev": "cd frontend && npm run dev",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "node scripts/build-backend.js",
    "build": "npm run build:frontend && npm run build:backend",
    "electron:build": "npm run build && electron-builder",
    "electron:build:win": "npm run build && electron-builder --win --x64",
    "electron:build:portable": "npm run build && electron-builder --win portable --x64",
    "electron:dev": "electron .",
    "clean": "rimraf release frontend/dist backend/dist",
    "rebuild-native": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.nexasoft.samagipos",
    "productName": "Samagi Hardware POS",
    "directories": {
      "output": "release",
      "buildResources": "electron"
    },
    "files": [
      "electron/**/*",
      "backend/dist/**/*",
      "frontend/dist/**/*",
      "package.json",
      "!**/node_modules/.cache",
      "!**/*.log",
      "!**/.DS_Store"
    ],
    "extraResources": [
      {
        "from": "backend/pos_database.sqlite",
        "to": "pos_database.sqlite"
      }
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*",
      "**/node_modules/sqlite3/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "electron/icon.ico",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.exe",
      "requestExecutionLevel": "user"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Samagi POS",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "MohamadRiza",
      "repo": "samagiHW_Pos-Release",
      "private": false,
      "releaseType": "release"
    }
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "axios": "^1.14.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "express-validator": "^7.3.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pdfkit": "^0.18.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "nodemon": "^3.1.14",
    "rimraf": "^5.0.10",
    "vite": "^8.0.1",
    "wait-on": "^7.2.0"
  }
}